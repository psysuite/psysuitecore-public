<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.fragments.AnswerDialogFragment">


    <TextView
        android:id="@+id/labInteractive"
        android:layout_width="120dp"
        android:layout_height="24dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="28dp"
        android:text="@string/interactivity"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labWhiteNoise" />

    <ImageButton
        android:id="@+id/bt_clear"
        android:layout_width="121dp"
        android:layout_height="63dp"
        android:layout_marginStart="40dp"
        android:background="@android:color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline8"
        app:srcCompat="@android:drawable/ic_menu_revert" />

    <ImageButton
        android:id="@+id/bt_confirm"
        android:layout_width="130dp"
        android:layout_height="62dp"
        android:layout_marginEnd="12dp"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline8"
        app:srcCompat="@drawable/green_tick" />

    <TextView
        android:id="@+id/labAge"
        android:layout_width="120dp"
        android:layout_height="24dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="28dp"
        android:text="@string/age"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labName" />

    <EditText
        android:id="@+id/txtAge"
        android:layout_width="140dp"
        android:layout_height="47dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="12dp"
        android:ems="10"
        android:inputType="none|number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtName" />

    <TextView
        android:id="@+id/labName"
        android:layout_width="120dp"
        android:layout_height="24dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="16dp"
        android:text="@string/name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
            android:id="@+id/txtName"
            android:layout_width="140dp"
            android:layout_height="46dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="12dp"
            android:ems="10"
            android:inputType="textPersonName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <RadioGroup
        android:id="@+id/radioGroupGender"
        android:layout_width="135dp"
        android:layout_height="42dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtAge">

        <RadioButton
            android:id="@+id/rb_male"
            android:layout_width="69dp"
            android:layout_height="45dp"
            android:text="@string/tid_rb_male_text" />

        <RadioButton
            android:id="@+id/rb_female"
            android:layout_width="65dp"
            android:layout_height="42dp"
            android:text="@string/tid_rb_female_text" />
    </RadioGroup>

    <Button
        android:id="@+id/bt_cancel"
        android:layout_width="357dp"
        android:layout_height="57dp"
        android:layout_marginTop="88dp"
        android:text="Cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.777"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline8" />

    <Spinner
        android:id="@+id/spCondition"
        android:layout_width="293dp"
        android:layout_height="31dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="12dp"
        android:textAlignment="viewEnd"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/radioGroupGender" />

    <Switch
        android:id="@+id/swInteractive"
        android:layout_width="140dp"
        android:layout_height="30dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/swWhiteNoise" />

    <TextView
        android:id="@+id/labSpinner"
        android:layout_width="120dp"
        android:layout_height="24dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="36dp"
        android:text="TEXT"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labInteractive" />

    <Spinner
        android:id="@+id/spinner"
        android:layout_width="140dp"
        android:layout_height="35dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/swInteractive" />

    <TextView
        android:id="@+id/labCondition"
        android:layout_width="220dp"
        android:layout_height="21dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="24dp"
        android:text="@string/condition"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labGender" />

    <TextView
        android:id="@+id/labGender"
        android:layout_width="120dp"
        android:layout_height="24dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="24dp"
        android:text="@string/gender"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labAge" />

    <TextView
        android:id="@+id/labWhiteNoise"
        android:layout_width="176dp"
        android:layout_height="24dp"
        android:layout_marginStart="36dp"
        android:layout_marginTop="56dp"
        android:text="@string/whitenoise"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spCondition" />


    <Switch
        android:id="@+id/swWhiteNoise"
        android:layout_width="69dp"
        android:layout_height="35dp"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spCondition" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="479dp" />

    <TextView
        android:id="@+id/labPopulation"
        android:layout_width="111dp"
        android:layout_height="24dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="44dp"
        android:text="@string/population"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labCondition" />

    <Spinner
        android:id="@+id/spPopulation"
        android:layout_width="138dp"
        android:layout_height="30dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spCondition" />

</androidx.constraintlayout.widget.ConstraintLayout>